# Copy to .env and adjust. All vars are prefixed MORPH_API_.

# Storage & persistence
MORPH_API_STORAGE_DIR=./api/data
# MORPH_API_DATABASE_URL=sqlite:////abs/path/api.db   # defaults to <storage_dir>/api.db
MORPH_API_LOG_DIR=./api/logs
MORPH_API_LOG_LEVEL=INFO
MORPH_API_ON_DUPLICATE=reject

# Task queue (Redis + RQ)
MORPH_API_REDIS_URL=redis://localhost:6379/0
MORPH_API_GPU_QUEUE_NAME=gpu
MORPH_API_JOB_TIMEOUT=3600
MORPH_API_ORTHANC_DEBOUNCE_SECONDS=10

# Docker model images
MORPH_API_NNUNET_IMAGE=swestfechtel/nnunet_torsion:latest
MORPH_API_TORSION_IMAGE=swestfechtel/torsion:latest
MORPH_API_DOCKER_SHM_SIZE=32G

# Auth & CORS (comma-separated). Empty API keys disables auth (dev only).
MORPH_API_API_KEYS=
MORPH_API_CORS_ALLOW_ORIGINS=*
